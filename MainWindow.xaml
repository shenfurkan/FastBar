<Window
    x:Class="FastBar.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FastBar"
    SizeToContent="WidthAndHeight"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    WindowStartupLocation="Manual"
    Loaded="Window_Loaded"
    Closed="Window_Closed"
    SourceInitialized="Window_SourceInitialized"
    StateChanged="Window_StateChanged">

    <!-- Outermost drop shadow and dragging area -->
    <Grid Margin="24" Width="560" Background="Transparent" MouseDown="Grid_MouseDown">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="1.3" ScaleY="1.3" />
        </Grid.LayoutTransform>
        <Border x:Name="MainBorder"
                BorderThickness="1.5"
                CornerRadius="22"
                Padding="0"
                Background="{DynamicResource ThemePrimaryBackground}"
                BorderBrush="{DynamicResource ThemeBorderBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="45" ShadowDepth="4" Opacity="0.25" Direction="270" Color="Black" />
            </Border.Effect>
            <StackPanel Background="Transparent">

                <!-- ── Search Header ── -->
                <Grid Height="44" Background="Transparent">
                    <!-- Search Input -->
                    <TextBox x:Name="SearchBox"
                             FontSize="18"
                             FontFamily="Google Sans"
                             FontWeight="Regular"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeTextForeground}"
                             BorderThickness="0"
                             Padding="24,0,24,0"
                             CaretBrush="{DynamicResource ThemeCaretBrush}"
                             Margin="0"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="22">
                                                <Grid Margin="{TemplateBinding Padding}">
                                                    <TextBlock
                                                        x:Name="Placeholder"
                                                        Text="FastBar Search"
                                                        Foreground="{DynamicResource ThemePlaceholderForeground}"
                                                        FontSize="17"
                                                        FontFamily="Google Sans"
                                                        FontWeight="Light"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Left"
                                                        IsHitTestVisible="False"
                                                        Margin="2,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <!-- ── Results List ── -->
                <ListBox x:Name="ResultList"
                         Background="Transparent"
                         Foreground="{DynamicResource ThemeTextForeground}"
                         BorderThickness="0"
                         Margin="6,4,6,6"
                         FontSize="14"
                         FontFamily="Google Sans"
                         FontWeight="Light"
                         Visibility="Collapsed"
                         SelectionChanged="ResultList_SelectionChanged"
                         MouseDoubleClick="ResultList_MouseDoubleClick"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="16,14"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Name="Bd" Padding="{TemplateBinding Padding}"
                                                CornerRadius="8" Background="Transparent"
                                                Margin="0,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeItemSelectedBackground}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource ThemeItemSelectedForeground}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeItemHoverBackground}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True" />
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeItemSelectedHoverBackground}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

            </StackPanel>
        </Border>
    </Grid>
</Window>
